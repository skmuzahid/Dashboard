# ── Google Sheets (Published CSV) ──
# File → Share → Publish to web → CSV
GOOGLE_CSV_URL=https://docs.google.com/spreadsheets/d/e/YOUR_ID/pub?gid=0&single=true&output=csv

# ── NextAuth ──
NEXTAUTH_SECRET=replace-with-a-random-32-char-string
NEXTAUTH_URL=http://localhost:3000

# ── Dashboard Users (JSON array) ──
# Add/remove users here. Only these people can log in.
DASHBOARD_USERS=[{"username":"admin","password":"admin123","name":"Admin"},{"username":"manager","password":"pass456","name":"Manager"}]

# ── Monthly Operational Costs (JSON: "Month - YYYY" → cost) ──\n# Each month maps to its operational cost. Summed per filter (single month, All, 3M, 6M, 1Y).\nNEXT_PUBLIC_OPERATIONAL_COSTS={"March - 2026":20000,"April - 2026":20000}

# ── Agent Salaries (JSON: normalized agent name → monthly salary) ──
NEXT_PUBLIC_AGENT_SALARIES={"Zaheer":5000,"Wshk":4000,"Awan":4500,"Arif":4000,"Moaiz":5000,"Roman":4500,"Arsalan":4000,"Momna":4500,"Nisreen":4000,"Parshu":3500,"Bomika":3500,"Shoaib":3500,"Aneel":3500}
